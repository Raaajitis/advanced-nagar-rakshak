{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "moduleResolution": "NodeNext",

    "resolveJsonModule": true,

    "types": ["node"]
  },

  "include": ["src"]
}